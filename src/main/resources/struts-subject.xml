<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE struts PUBLIC "-//Apache Software Foundation//DTD Struts Configuration 6.0//EN" "https://struts.apache.org/dtds/struts-6.0.dtd">
<struts>
    <package name="subject" namespace="/subject" extends="base">
        <default-interceptor-ref name="protectedStack" />
        <default-action-ref name="index" />

        <action name="index" class="me.dgrachov.studyplanner.action.subject.ShowSubjectsAction">
            <result name="success" type="tiles">subjects</result>
            <result name="error" type="tiles">subjects</result>
        </action>

        <action name="create" class="me.dgrachov.studyplanner.action.subject.CreateSubjectAction">
            <result name="success" type="redirect">index</result>
            <result name="showPage" type="tiles">createSubject</result>
            <result name="error" type="tiles">createSubject</result>
        </action>

        <action name="edit" class="me.dgrachov.studyplanner.action.subject.EditSubjectAction">
            <result name="success" type="redirect">index</result>
            <result name="showPage" type="tiles">editSubject</result>
            <result name="error" type="tiles">editSubject</result>
        </action>

        <action name="delete" class="me.dgrachov.studyplanner.action.subject.DeleteSubjectAction">
            <result name="success" type="redirect">index</result>
            <result name="error" type="tiles">subjects</result>
        </action>
    </package>
</struts>
