<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE struts PUBLIC "-//Apache Software Foundation//DTD Struts Configuration 6.0//EN" "https://struts.apache.org/dtds/struts-6.0.dtd">
<struts>
    <package name="checklistItem" namespace="/checklistItem" extends="base">
    
        <default-interceptor-ref name="protectedStack" />
        <default-action-ref name="index" />
        
        <action name="index" class="me.dgrachov.studyplanner.action.checklist.ShowChecklistItemAction">
            <result name="success" type="tiles">editChecklist</result>
            <result name="error" type="tiles">editChecklist</result>
        </action>

        <action name="create" class="me.dgrachov.studyplanner.action.checklist.CreateChecklistItemAction">
            <result name="success" type="redirectAction">
			    <param name="actionName">index</param>
			    <param name="namespace">/checklistItem</param>
			    <param name="checklistId">${checklistId}</param>
			</result>
            <result name="showPage" type="tiles">editChecklist</result>
            <result name="error" type="tiles">editChecklist</result>
        </action>

    </package>
</struts>
